# Nebius Token Factory — required for mini-swe-agent API calls
NEBIUS_API_KEY=XXX

# MLflow (start with scripts/start_mlflow.sh)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=swe-bench-agent-eval

# Path to mini-swe-agent benchmark config (default: sibling clone on VM)
# MINI_SWE_CONFIG=../mini-swe-agent/src/minisweagent/config/benchmarks/swebench.yaml

# Optional: remote artifact URI after S3 upload (logged to MLflow)
# RUN_ARTIFACT_URI=s3://your-bucket/runs/<run-id>/

# Optional: Nebius Object Storage (Phase 3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=
# S3_BUCKET=
